{
  "name": "@modelcontextprotocol/inspector",
  "version": "2.0.0",
  "description": "The Model Context Protocol Inspector",
  "keywords": [
    "MCP",
    "inspector"
  ],
  "homepage": "https://github.com/modelcontextprotocol/inspector#readme",
  "bugs": {
    "url": "https://github.com/modelcontextprotocol/inspector/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modelcontextprotocol/inspector.git"
  },
  "license": "MIT",
  "author": "The MCP Maintainers and Community",
  "type": "module",
  "bin": {
    "mcp-inspector": "./clients/launcher/build/index.js"
  },
  "files": [
    "clients/launcher/build",
    "clients/web/build",
    "clients/web/dist",
    "clients/cli/build",
    "clients/tui/build",
    "scripts/install-clients.mjs"
  ],
  "scripts": {
    "build": "npm run build:web && npm run build:cli && npm run build:tui && npm run build:launcher",
    "build:web": "cd clients/web && npm run build",
    "build:cli": "cd clients/cli && npm run build",
    "build:tui": "cd clients/tui && npm run build",
    "build:launcher": "cd clients/launcher && npm run build",
    "prepack": "npm run build",
    "test:cli": "cd clients/cli && npm run test",
    "test:tui": "cd clients/tui && npm run test",
    "validate": "npm run validate:web && npm run test:cli && npm run test:tui && npm run validate:launcher",
    "validate:web": "cd clients/web && npm run validate",
    "validate:launcher": "npm run build:cli && npm run build:tui && npm run build:launcher && npm run smoke:launcher",
    "smoke:launcher": "node clients/launcher/build/index.js --help && node clients/launcher/build/index.js --cli --help && node clients/launcher/build/index.js --tui --help",
    "test": "cd ./clients/web/ && npm run test && cd ../cli && npm run test && cd ../tui && npm run test",
    "test:coverage": "cd ./clients/web/ && npm run test:coverage",
    "test:storybook": "cd ./clients/web/ && npm run test:storybook",
    "inspector": "node clients/launcher/build/index.js",
    "web": "node clients/launcher/build/index.js --web",
    "web:dev": "node clients/launcher/build/index.js --web --dev",
    "postinstall": "node scripts/install-clients.mjs",
    "install:clients": "node scripts/install-clients.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@modelcontextprotocol/ext-apps": "^1.7.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "@vitejs/plugin-react": "^6.0.0",
    "ajv": "^8.17.1",
    "atomically": "^2.1.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "hono": "^4.12.18",
    "ink": "^6.0.0",
    "ink-form": "^2.0.1",
    "ink-scroll-view": "^0.3.6",
    "open": "^10.2.0",
    "pino": "^9.14.0",
    "react": "^19.2.4",
    "vite": "^8.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "ink-select-input": "^6.2.0"
  },
  "engines": {
    "node": ">=22.7.5"
  }
}
