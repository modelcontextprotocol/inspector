{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./build",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "typeRoots": ["../clients/web/node_modules/@types"],
    "paths": {
      "yaml": ["../clients/web/node_modules/yaml"],
      "vitest": ["../clients/web/node_modules/vitest"],
      "express": ["../clients/web/node_modules/@types/express"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "build"]
}
