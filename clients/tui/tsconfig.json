{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    // Mirror clients/web/tsconfig.app.json's effective options so this
    // typecheck validates the imported `core/` sources against the exact
    // config web's own gate already uses (web's app config does not extend
    // tsconfig.base, so it has no `noUncheckedIndexedAccess`; re-enabling it
    // here would surface core issues web never gates). DOM lib + bundler
    // resolution are what core/ (browser-side auth, DOM types) expects; the
    // `react` path redirect lets core/ source resolve its bare `react` import
    // from this client's node_modules.
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "module": "ESNext",
    "noUncheckedIndexedAccess": false,
    "paths": {
      "@inspector/core/*": ["../../core/*"],
      "react": ["./node_modules/@types/react"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime"]
    }
  },
  "include": ["index.ts", "tui.tsx", "src/**/*"],
  "exclude": ["node_modules", "**/*.test.ts", "build"]
}
